<?xml version="1.0"?>
<robot name="robot_mino" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <material name="dark_gray"><color rgba="0.5 0.5 0.5 1"/></material>
  <material name="bright_red"><color rgba="0.1 0.1 0.1 1"/></material>
  <material name="blue"><color rgba="1.0 0.5 0.0 1"/></material>
  <material name="gripper_alu"><color rgba="0.8 0.8 0.8 1"/></material>

  <!-- ====== UKURAN FISIK — WAJIB DIVALIDASI DENGAN PENGGARIS ASLI ====== -->
  <xacro:property name="wheel_radius" value="0.026"/>       <!-- [CEK] samakan dgn controllers.yaml -->
  <xacro:property name="wheel_separation" value="0.20"/>    <!-- [UKUR ULANG] jarak roda kemungkinan berubah krn plat lebih lebar -->
  <xacro:property name="wheel_width" value="0.02"/>

  <!-- Base sekarang LINGKARAN diameter 26 cm (bukan kotak lagi) -->
  <xacro:property name="base_radius" value="0.13"/>
  <xacro:property name="base_height" value="0.05"/>

<!-- Capit / gripper depan: area dudukan 7 x 9 cm -->
<xacro:property name="gripper_length" value="0.07"/>      <!-- depan-belakang (menghadap depan) -->
<xacro:property name="gripper_width" value="0.09"/>       <!-- sisi kiri-kanan -->
<xacro:property name="gripper_height" value="0.035"/>
<xacro:property name="gripper_offset_x" value="${base_radius - 0.03 + gripper_length/2}"/> <!-- depan capit menjorok ~4cm di luar body -->

  <link name="base_footprint"/>

  <link name="base_link">
    <visual>
      <geometry><cylinder radius="${base_radius}" length="${base_height}"/></geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <geometry><cylinder radius="${base_radius}" length="${base_height}"/></geometry>
    </collision>
    <inertial>
      <mass value="1.8"/> <!-- [UKUR ULANG] massa total kemungkinan naik krn plat lebih besar + capit -->
      <inertia ixx="0.015" ixy="0" ixz="0" iyy="0.015" iyz="0" izz="0.02"/>
    </inertial>
  </link>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <xacro:macro name="wheel" params="prefix y_offset">
    <link name="${prefix}_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
        <material name="bright_red"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      </collision>
      <inertial>
        <mass value="0.05"/>
        <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
      </inertial>
    </link>
    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_wheel_link"/>
      <origin xyz="0 ${y_offset} -${wheel_radius}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <xacro:wheel prefix="left"  y_offset="${wheel_separation/2}"/>
  <xacro:wheel prefix="right" y_offset="-${wheel_separation/2}"/>

  <link name="imu_link"/>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.02" rpy="0 0 0"/>
  </joint>

  <!-- Lidar sekarang TEPAT DI TENGAH -->
  <link name="lidar_link">
    <visual>
      <geometry><cylinder radius="0.03" length="0.025"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.03" length="0.025"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <!-- x=0 y=0 karena lidar di pusat. z & yaw kalibrasi lama (4.71239) dipertahankan -->
    <origin xyz="0 0 0.0375" rpy="0 0 4.71239"/>
  </joint>

  <!-- ====== CAPIT DEPAN (dudukan servo) — dipakai utk footprint & collision Nav2 ====== -->
  <link name="gripper_base_link">
    <visual>
      <geometry><box size="${gripper_length} ${gripper_width} ${gripper_height}"/></geometry>
      <material name="gripper_alu"/>
    </visual>
    <collision>
      <geometry><box size="${gripper_length} ${gripper_width} ${gripper_height}"/></geometry>
    </collision>
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0002"/>
    </inertial>
  </link>

  <!-- [PENTING] Capit SEJAJAR piringan (bukan menjulang di atas pusat) -->
  <!-- artinya base capit ~setinggi bidang scan lidar -> self-detection nyaris pasti terjadi -->
  <!-- kalau tidak difilter di laser_filters.yaml (lihat penjelasan) -->
  <joint name="gripper_base_joint" type="fixed">
    <parent link="base_link"/>
    <child link="gripper_base_link"/>
    <origin xyz="${gripper_offset_x} 0 ${base_height/2 - gripper_height/2}" rpy="0 0 0"/>
  </joint>

  <ros2_control name="RobotMinoSystem" type="system">
    <hardware>
      <plugin>topic_based_ros2_control/TopicBasedSystem</plugin>
      <param name="joint_commands_topic">/topic_based_joint_commands</param>
      <param name="joint_states_topic">/topic_based_joint_states</param>
      <param name="trigger_joint_command_threshold">-1</param>
    </hardware>
    <joint name="left_wheel_joint">  <xacro:property name="gripper_length" value="0.07"/>      <!-- depan-belakang (menghadap depan) -->
  <xacro:property name="gripper_width" value="0.09"/>       <!-- sisi kiri-kanan -->
  <xacro:property name="gripper_height" value="0.12"/>
  <xacro:property name="gripper_offset_x" value="${base_radius + gripper_length/2 - 0.005}"/>
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="right_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

</robot>
